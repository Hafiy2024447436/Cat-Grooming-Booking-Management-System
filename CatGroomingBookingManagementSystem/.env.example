# Local PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/cat_grooming
DB_USER=postgres
DB_PASSWORD=change_me
DB_AUTO_INIT=false

# SMTP / Gmail App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=your_gmail@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM_EMAIL=your_gmail@gmail.com
SMTP_FROM_NAME=Meowy Groom
SMTP_SSL=true
SMTP_STARTTLS=false

# Optional notification microservice
NOTIFICATION_BOOKING_CONFIRMED_URL=https://your-notification-service.example/api/notifications/booking-confirmed

# Optional first owner creation on an empty cloud database
BOOTSTRAP_OWNER_USERNAME=owner
BOOTSTRAP_OWNER_PASSWORD=replace_with_a_strong_password
BOOTSTRAP_OWNER_NAME=System Owner
BOOTSTRAP_OWNER_EMAIL=owner@example.com
BOOTSTRAP_OWNER_PHONE=0000000000
BOOTSTRAP_OWNER_ADDRESS=Pending update
